rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation helper for Portfolio data structure
    function isValidPortfolio(data) {
      return data.keys().hasAll(['personal', 'projects', 'experience', 'skills', 'customization'])
        && data.personal is map
        && data.personal.name is string
        && data.personal.name.size() > 0
        && data.projects is list
        && data.experience is list
        && data.skills is list
        && data.customization is map;
    }

    // Match block for portfolios collection
    match /portfolios/{portfolioId} {
      allow read: if isValidId(portfolioId);
      allow write: if isValidId(portfolioId) && isValidPortfolio(incoming());
    }
  }
}
